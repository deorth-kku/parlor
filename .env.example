# OpenAI-compatible backend settings
# OPENAI_BASE_URL=http://127.0.0.1:8080/v1
# OPENAI_API_KEY=your-key-if-needed
# OPENAI_MODEL=gemma-4-12b-it
# Omit OPENAI_MODEL to use the endpoint's default model
# OPENAI_TIMEOUT=120
# OPENAI_TEMPERATURE=0.2
# OPENAI_MAX_TOKENS=256
# OPENAI_STRUCTURED_OUTPUT_MODE=auto
# auto: use JSON Schema when the model looks compatible, otherwise prompt-only JSON
# schema: always send response_format json_schema
# prompt: never send response_format; ask the model to emit plain JSON text instead

# Server port (default: 8000)
# PORT=8000
